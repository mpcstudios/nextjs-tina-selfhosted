# TinaCMS Self-Hosted Configuration
#
# In production, all values come from Infisical via the Vercel sync — you don't
# fill these in by hand on a deployed site. See CLAUDE.md → "New-site setup
# ritual". This file is only useful for `dev:prod` testing.

# GitHub App auth (commits content edits as mpc-studios-cms[bot])
# These come from Infisical mpc-shared/prod (App ID + private key) and
# site-<slug>/prod (installation ID).
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=

# Optional GitHub overrides (defaults read from VERCEL_GIT_* on Vercel)
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=

# NextAuth.js (admin sign-in JWT signing key)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Upstash Redis (TinaCMS database layer) — auto-provisioned by the deploy button
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AWS S3 (media uploads) — shared mpcstudios-media bucket
# Access keys belong to the mpcstudios-cms-uploads service IAM user (in
# Infisical mpc-shared/prod). Only S3_MEDIA_ROOT changes per site.
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=mpcstudios-media
S3_MEDIA_ROOT=my-site-name
