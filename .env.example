# TinaCMS Self-Hosted Configuration
# Copy this file to .env.local and fill in the values.

# GitHub (for content storage via git)
GITHUB_PERSONAL_ACCESS_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=

# NextAuth.js (for admin authentication)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Upstash Redis (for TinaCMS database layer)
# Create at: https://console.upstash.com or via Vercel KV integration
KV_REST_API_URL=
KV_REST_API_TOKEN=

# AWS S3 (for media uploads)
# All MPC sites share the mpcstudios-media bucket.
# Only S3_MEDIA_ROOT changes per site (set to your project name).
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
S3_BUCKET=mpcstudios-media
S3_MEDIA_ROOT=my-site-name
